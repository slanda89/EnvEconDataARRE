    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20230629-1836; environment: PROD; CERES: 4.19.0; IMMC2CDM: 3.2.2; rules: ; builddate: 2023-06-29T05:03:40.495;</j.2:build_info>
