  <rdf:Description rdf:nodeID="A3">
    <j.2:build_info rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reception-ID: PO-20230712-3760; environment: PROD; CERES: 4.20.1; IMMC2CDM: 3.2.2; rules: ; builddate: 2023-07-12T09:12:17.433;</j.2:build_info>
