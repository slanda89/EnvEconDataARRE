{
  "metadata": {
    "purpose": "Country-language-aware conservative keyword configuration for assessing SEEA account availability from downloaded official files.",
    "research_use_note": "This file is designed for transparent, reproducible screening. It should be described as a conservative dictionary-based text-mining instrument, not as a certified legal or linguistic translation standard.",
    "matching_principle": "A generated keyword should combine an account/accounting term with an SEEA account topic. Topic-only words such as water, energy, forest, land, carbon, ocean, species, taxes, or subsidies should not be used alone as availability evidence.",
    "country_language_scope": "Every country in the 2024 Global Assessment sheet is mapped to English plus the main official or commonly used statistical-publication language(s). English is intentionally retained for all countries where national statistical offices commonly publish English pages or metadata.",
    "translation_scope": "Account/accounting words are provided for every language listed in country_languages. Topic translations are complete for English, Spanish, French, and Portuguese, broad for German and several European languages, and intentionally partial for languages where unvalidated literal translation could reduce research reliability.",
    "justification": "For research publication, report that the method uses exact and generated account-name phrases, preserves all generated phrases in the keyword_dictionary output sheet, logs file-read failures, and treats uncertain or topic-only matches as not available.",
    "recommended_validation": "Manually review availability_evidence and keyword_dictionary for high-impact findings, especially nonreport_avail = 1, before using results as final analytical claims."
  },
